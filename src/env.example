# App
APP_NAME="RideDelivery API"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ridedelivery
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/ridedelivery

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# M-Pesa Daraja (Safaricom)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mpesa/callback
MPESA_ENV=sandbox

# Rider Assignment
RIDER_RESPONSE_TIMEOUT_SECONDS=300
MAX_SEARCH_RADIUS_KM=10
INITIAL_SEARCH_RADIUS_KM=3
